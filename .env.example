# KlusAI Environment Variables
# Copy this file to packages/backend/.env and fill in your values

# Google AI (Gemini) — get your key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./klusai.db

# SAM Model (for image segmentation)
SAM_MODEL_PATH=./data/models/mobile_sam.pt
SAM_MODEL_TYPE=vit_t

# Server
HOST=0.0.0.0
PORT=8000
